# ─────────────────────────────────────────────────────────
# KAALI Phase 2 — Environment Variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# ─────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AUTH ──────────────────────────────────────────────────
JWT_SECRET=replace-with-openssl-rand-base64-32
JWT_EXPIRES_IN=7d

# ── APP ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── EMAIL ─────────────────────────────────────────────────
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-ethereal-user
EMAIL_PASS=your-ethereal-pass
EMAIL_FROM="Kaali <noreply@kaali.absoluteapplabs.com>"

# ── STRIPE ────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Get from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in Stripe Dashboard → Products
STRIPE_PRICE_GROWTH=price_...     # $29/mo
STRIPE_PRICE_BUSINESS=price_...   # $79/mo

# ── HUBSPOT ───────────────────────────────────────────────
# Get from: HubSpot → Settings → Integrations → Private Apps
# Scopes needed: crm.objects.contacts.write, crm.objects.contacts.read
HUBSPOT_ACCESS_TOKEN=pat-na1-...
# Optional: push leads to a specific HubSpot form instead of Contacts API
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID=

# ── PLATFORM AI KEYS (optional fallback for free tier) ────
PLATFORM_ANTHROPIC_KEY=
PLATFORM_OPENAI_KEY=
